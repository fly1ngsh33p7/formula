{
    "compilerOptions": {
        "target": "es6",
        "module": "es6",
        "lib": ["ES6", "DOM"],
        "moduleResolution": "Bundler",
        "rootDir": "src",
        "outDir": "dist",
        "strict": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "sourceMap": true
    },
    "include": ["src/**/*.ts"]
}
